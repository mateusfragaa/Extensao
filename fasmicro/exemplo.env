; URL base do framework (FasMicro)
BASEURL=http://fasmicro/

; Ambiente da base dados
ENVIRIONMENT=DEVELOPMENT
;ENVIRIONMENT=PRODUCTION

[DEVELOPMENT]
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fasmicro
DB_USER=root
DB_PASSWORD=

[PRODUCTION]
DB_CONNECTION=mysql
DB_HOST=fasmicro.com.br
DB_PORT=3306
DB_DATABASE=fasmicro
DB_USER=fasmicro
DB_PASSWORD=fas@micro#12345

; Conta para disparo de e-mail
MAIL.HOST=smtp.gmail.com
MAIL.SMTPAuth=true
MAIL.PORT=587
MAIL.SMTPSECURE=tls
MAIL.NOME=Contato FasMicro
MAIL.USER=fasmicro@gmail.com
MAIL.SENHA=sua_senha